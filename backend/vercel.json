{
  "version": 2,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/index.js"
    }
  ],
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "buildCommand": "esbuild ./src/index.ts --bundle --outdir=./dist --minify --platform=node --packages=external",
  "startCommand": "node ./dist/index.js"
}

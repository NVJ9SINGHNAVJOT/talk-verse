{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
  ],
  "scripts": {
    "build": "esbuild ./src/index.ts --bundle --outdir=./dist --minify --platform=node --packages=external",
    "start": "node ./dist/index.js"
  }
}
